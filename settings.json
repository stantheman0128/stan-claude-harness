{
  "cleanupPeriodDays": 3650,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_WORKFLOWS": "1",
    "DISABLE_GROWTHBOOK": "1",
    "PYTHONUTF8": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "WebFetch(*)",
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Task(*)",
      "Skill(*)",
      "mcp__claude-in-chrome",
      "mcp__claude_ai_Google_Drive",
      "mcp__claude_ai_Read_AI",
      "mcp__claude_ai_Vercel",
      "mcp__claude_ai_Notion",
      "mcp__supabase",
      "mcp__plugin_claude-mem_mcp-search",
      "mcp__plugin_cloudflare_cloudflare-api",
      "mcp__plugin_cloudflare_cloudflare-bindings",
      "mcp__plugin_cloudflare_cloudflare-builds",
      "mcp__plugin_cloudflare_cloudflare-docs",
      "mcp__plugin_cloudflare_cloudflare-observability",
      "mcp__plugin_context7_context7",
      "mcp__plugin_playwright_playwright",
      "mcp__plugin_superpowers-chrome_chrome"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(rmdir *)",
      "Bash(mv *)",
      "Bash(del *)",
      "Bash(shutdown *)",
      "Bash(format *)",
      "Bash(reboot *)"
    ],
    "ask": [
      "Bash(git push --force *)",
      "Bash(git rebase *)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "py \"C:/Users/stans/.claude/hooks/careful_guard.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "py \"C:/Users/stans/.claude/hooks/research_guard.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:19280/"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:/Users/stans/.claude/hooks/claude-mem-port-sync.sh\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:/Users/stans/.claude/hooks/fix-claude-mem-windows.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/stans/.claude/hooks/claude-mem-sync.mjs\" download",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:19280/"
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:/Users/stans/.claude/hooks/claude-mem-context.sh\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "py \"C:/Users/stans/.claude/hooks/skill-routing-watch.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:19280/"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "py \"C:/Users/stans/.claude/hooks/twify-session-name.py\"",
            "timeout": 15
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/stans/.claude/hooks/claude-mem-sync.mjs\" upload",
            "timeout": 120
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "py \"C:/Users/stans/.claude/hooks/skill-usage-log.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:19280/"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:19280/"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:19280/"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "py \"C:/Users/stans/.claude/hooks/twify-session-name.py\"",
            "timeout": 15
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "py \"C:/Users/stans/.claude/hooks/skill-suggest.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:19280/"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash C:/Users/stans/.claude/statusline.sh",
    "padding": 1
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": false,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": false,
    "github@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false,
