    "clangd-lsp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": false,
    "csharp-lsp@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": false,
    "hookify@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": false,
    "kotlin-lsp@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": false,
    "php-lsp@claude-plugins-official": false,
    "playground@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "double-shot-latte@superpowers-marketplace": false,
    "episodic-memory@superpowers-marketplace": false,
    "superpowers-developing-for-claude-code@superpowers-marketplace": false,
    "superpowers-chrome@superpowers-marketplace": false,
    "claude-session-driver@superpowers-marketplace": false,
    "claude-mem@thedotmack": true,
    "zeabur@zeabur": true,
    "project-sweep@stan-local-plugins": true,
    "loop-gate@stan-local-plugins": true,
    "document-skills@anthropic-agent-skills": true,
    "superpowers@superpowers-marketplace": true,
    "cloudflare@cloudflare": true,
    "superpowers@claude-plugins-official": false,
    "claude-api@anthropic-agent-skills": false,
    "playwright@claude-plugins-official": true,
    "agent-skills@addy-agent-skills": true,
    "chrisbanes-skills@chrisbanes-skills": false,
    "modern-web-guidance@googlechrome": false,
    "static-analysis@trailofbits": false,
    "impeccable@impeccable": true
  },
  "skillOverrides": {
    "adversarial-review": "off",
    "analyze-forks": "off",
    "careful": "off",
    "codebase-design": "off",
    "context-compression": "off",
